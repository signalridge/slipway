{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "go",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "draft": false,
      "prerelease": false,
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "refactor",
          "section": "Refactoring"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "security",
          "section": "Security"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "docs",
          "section": "Documentation",
          "hidden": true
        },
        {
          "type": "style",
          "section": "Styles",
          "hidden": true
        },
        {
          "type": "chore",
          "section": "Chores",
          "hidden": true
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": true
        },
        {
          "type": "ci",
          "section": "CI",
          "hidden": true
        },
        {
          "type": "build",
          "section": "Build",
          "hidden": true
        }
      ],
      "extra-files": []
    }
  },
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release ${version}",
  "pull-request-title-pattern": "chore: release ${version}",
  "pull-request-header": "This PR was automatically created by release-please.",
  "pull-request-footer": "---\n\nAfter this PR is merged, the tag-based release workflow builds and verifies Slipway artifacts.",
  "sequential-calls": false,
  "plugins": []
}
