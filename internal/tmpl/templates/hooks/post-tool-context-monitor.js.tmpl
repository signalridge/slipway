#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const os = require('os');

// Debounce: skip if last invocation was within DEBOUNCE_CALLS tool calls.
const DEBOUNCE_CALLS = 5;
const SPAWN_TIMEOUT_MS = 5000;

function resolveProjectRoot(startDir) {
  try {
    const result = spawnSync('slipway', ['root'], {
      cwd: startDir,
      encoding: 'utf8',
      timeout: SPAWN_TIMEOUT_MS,
    });
    if (result.error || result.status !== 0 || !result.stdout) {
      return {
        projectRoot: '',
        diagnostic: `hook_diagnostic: slipway root failed: ${
          normalizeHookMessage(
            result.stderr || result.stdout || (result.error ? result.error.message : '')
          ) || 'unknown error'
        }`,
      };
    }
    return { projectRoot: result.stdout.trim(), diagnostic: '' };
  } catch {
    return {
      projectRoot: '',
      diagnostic: 'hook_diagnostic: slipway root failed: unknown error',
    };
  }
}

function normalizeHookMessage(value) {
  return String(value || '')
    .replace(/[\r\n]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function getBridgePath(projectRoot) {
  const sessionId = process.env.SESSION_ID || process.ppid || 'default';
  // Include a scope-root-scoped hash so subdirectories within the same
  // workspace share a debounce counter.
  const crypto = require('crypto');
  const rootHash = crypto.createHash('md5').update(projectRoot).digest('hex').slice(0, 8);
  return path.join(os.tmpdir(), `slipway-ctx-${sessionId}-${rootHash}.json`);
}

function readBridge(bridgePath) {
  try {
    return JSON.parse(fs.readFileSync(bridgePath, 'utf8'));
  } catch {
    return { callsSinceLastCheck: 0 };
  }
}

function writeBridge(bridgePath, data) {
  try {
    fs.writeFileSync(bridgePath, JSON.stringify(data), 'utf8');
  } catch {
    // best-effort
  }
}

let input = '';
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk => {
  input += chunk;
});
process.stdin.on('end', () => {
  try {
    const payload = input.trim() ? JSON.parse(input) : {};
    const cwd = payload.cwd || process.cwd();
    const rootResolution = resolveProjectRoot(cwd);
    const projectRoot = rootResolution.projectRoot;
    if (!projectRoot) {
      if (rootResolution.diagnostic) {
        process.stdout.write(JSON.stringify({
          hookSpecificOutput: {
            hookEventName: '{{.HookEvent}}',
            additionalContext: rootResolution.diagnostic,
          },
        }));
      }
      process.exit(0);
    }

    const bridgePath = getBridgePath(projectRoot);
    const bridge = readBridge(bridgePath);
    bridge.callsSinceLastCheck = (bridge.callsSinceLastCheck || 0) + 1;

    // Debounce: only run the CLI check every DEBOUNCE_CALLS invocations.
    if (bridge.callsSinceLastCheck < DEBOUNCE_CALLS) {
      writeBridge(bridgePath, bridge);
      process.exit(0);
    }

    // Reset counter and perform the check.
    bridge.callsSinceLastCheck = 0;
    writeBridge(bridgePath, bridge);

    // Preserve the caller's worktree identity. `slipway root` returns the
    // canonical scope root, which may live in the main repo even when the
    // active session is inside a bound worktree.
    const result = spawnSync('slipway', ['next', '--preview', '--context-guard'], {
      cwd,
      encoding: 'utf8',
      timeout: SPAWN_TIMEOUT_MS,
    });
    let additionalContext = '';
    if (result.error || result.status !== 0) {
      const detail = normalizeHookMessage(
        result.stderr || result.stdout || (result.error ? result.error.message : '')
      );
      additionalContext = `hook_diagnostic: slipway next --preview --context-guard failed: ${detail || 'unknown error'}`;
    } else {
      additionalContext = (result.stdout || '').trim();
    }
    if (!additionalContext) {
      process.exit(0);
    }

    process.stdout.write(JSON.stringify({
      hookSpecificOutput: {
        hookEventName: '{{.HookEvent}}',
        additionalContext,
      },
    }));
  } catch (err) {
    process.exit(0);
  }
});
