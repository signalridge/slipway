#!/usr/bin/env bash
set -euo pipefail

# Slipway session-start hook helper for {{.ToolID}}.
# This hook is intentionally read-only:
# - next provides a compact handoff (query-only, no state advancement)

if ! command -v slipway >/dev/null 2>&1; then
  exit 0
fi

normalize_hook_message() {
  printf '%s' "$1" | tr '\r\n' ' ' | sed -e 's/[[:space:]][[:space:]]*/ /g' -e 's/^ //' -e 's/ $//'
}

extract_json_string_field() {
  local input="$1"
  local field="$2"
  printf '%s' "${input}" | sed -nE 's/.*"'"${field}"'"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' | head -n 1
}

unescape_json_string() {
  printf '%s' "$1" | sed -e 's/\\"/"/g' -e 's/\\\\/\\/g'
}

format_bound_worktree_handoff() {
  local output
  local normalized
  local slug
  local worktree_path
  output="$1"
  normalized="$(normalize_hook_message "${output}")"
  if ! printf '%s' "${normalized}" | grep -q '"error_code"[[:space:]]*:[[:space:]]*"change_bound_to_other_worktree"'; then
    return 1
  fi
  slug="$(extract_json_string_field "${normalized}" "slug")"
  worktree_path="$(extract_json_string_field "${normalized}" "worktree_path")"
  slug="$(unescape_json_string "${slug}")"
  worktree_path="$(unescape_json_string "${worktree_path}")"
  if [ -z "${slug}" ] || [ -z "${worktree_path}" ]; then
    return 1
  fi
  printf 'session_handoff_info: no active change in this worktree; active change %s is bound to %s; cd there or use --change %s to act' "${slug}" "${worktree_path}" "${slug}"
}

diagnostics=()
hook_cwd="$(pwd -P 2>/dev/null || pwd)"
project_root=""
if project_root_output="$(slipway root 2>&1)"; then
  project_root="${project_root_output}"
else
  diagnostics+=("hook_diagnostic: slipway root failed: $(normalize_hook_message "${project_root_output}")")
fi
if [ -z "${project_root}" ]; then
  if [ "${#diagnostics[@]}" -eq 0 ]; then
    exit 0
  fi
  diagnostics_text="$(printf '%s\n' "${diagnostics[@]}")"
  cat <<EOF
<slipway-session-start tool="{{.ToolID}}">
${diagnostics_text}
</slipway-session-start>
EOF
  exit 0
fi

run_slipway_readonly() {
  local output
  local status
  set +e
  output="$(cd "${hook_cwd}" && slipway "$@" 2>&1)"
  status=$?
  set -e
  printf '%s' "${output}"
  return "${status}"
}

next_json=""
handoff_info=""
if next_output="$(run_slipway_readonly next --json)"; then
  next_json="${next_output}"
elif handoff_info="$(format_bound_worktree_handoff "${next_output}")"; then
  :
else
  diagnostics+=("hook_diagnostic: slipway next --json failed: $(normalize_hook_message "${next_output}")")
fi

diagnostics_text=""
if [ "${#diagnostics[@]}" -gt 0 ]; then
  diagnostics_text="$(printf '%s\n' "${diagnostics[@]}")"
fi

handoff_path=""
git_common_dir="$(git -C "${project_root}" rev-parse --git-common-dir 2>/dev/null || true)"
if [ -n "${git_common_dir}" ]; then
  # Make absolute relative to project_root when git returns a relative path.
  if [ "${git_common_dir}" = "${git_common_dir#/}" ]; then
    git_common_dir="${project_root}/${git_common_dir}"
  fi
  git_common_dir="$(cd "${git_common_dir}" 2>/dev/null && pwd -P || printf '%s\n' "${git_common_dir}")"
  canonical_project_root="$(cd "${project_root}" 2>/dev/null && pwd -P || printf '%s\n' "${project_root}")"
  repo_root="$(git -C "${project_root}" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "${repo_root}" ]; then
    repo_root="$(cd "${repo_root}" 2>/dev/null && pwd -P || printf '%s\n' "${repo_root}")"
  fi
  scope_rel=""
  if [ -n "${repo_root}" ] && [ "${canonical_project_root}" != "${repo_root}" ]; then
    case "${canonical_project_root}" in
      "${repo_root}"/*)
        scope_rel="${canonical_project_root#${repo_root}/}"
        ;;
    esac
  fi
  if [ -n "${scope_rel}" ]; then
    handoff_path="${git_common_dir%/}/slipway/scopes/${scope_rel}/runtime/handoff.md"
  else
    handoff_path="${git_common_dir%/}/slipway/runtime/handoff.md"
  fi
fi
handoff_summary=""
if [ -n "${handoff_path}" ]; then
  handoff_present="false"
  if [ -f "${handoff_path}" ]; then
    handoff_present="true"
  fi
  handoff_summary="$(printf 'session_handoff_present: %s\nsession_handoff_path: %s' "${handoff_present}" "${handoff_path}")"
fi

if [ -z "${next_json}" ] && [ -z "${handoff_info}" ] && [ -z "${handoff_summary}" ] && [ -z "${diagnostics_text}" ]; then
  exit 0
fi

cat <<EOF
<slipway-session-start tool="{{.ToolID}}">
slipway_entry_skill: This repository is governed by Slipway. To drive any non-trivial change through the governed lifecycle, load the "{{.EntrySkill}}" skill — the entry point that routes new/next/run/done.
${next_json}
${handoff_info}
${diagnostics_text}
${handoff_summary}
</slipway-session-start>
EOF
